{
  "name": "cyclingappnew",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "prestart": "node scripts/check_local_data.js",
    "preios": "node scripts/check_local_data.js",
    "preandroid": "node scripts/check_local_data.js",
    "preweb": "node scripts/check_local_data.js",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint src/ --ext .ts,.tsx --ignore-pattern src/generated/pcsData.ts",
    "format": "prettier --write src/ scripts/",
    "fetch-races": "python3 scripts/fetch_races.py",
    "fetch-races-full": "python3 scripts/fetch_races.py --full-season"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-navigation/native": "^7.1.3",
    "@react-navigation/native-stack": "^7.14.2",
    "dayjs": "^1.11.13",
    "expo": "^55.0.4",
    "expo-linear-gradient": "~55.0.8",
    "react": "^19.2.0",
    "react-native": "^0.83.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.2.10",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "private": true
}
